{
  "expo": {
    "name": "HopOn",
    "slug": "hopon",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hopon",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2018"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hopon.app",
      "infoPlist": {
        "NSCameraUsageDescription": "HopOn uses your camera to attach photos to tasks and horse updates.",
        "NSPhotoLibraryUsageDescription": "HopOn uses your photo library to upload horse photos and task evidence.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": ["applinks:hopon.app"]
    },
    "android": {
      "package": "com.hopon.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D2018"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "https", "host": "hopon.app" }],
          "category": ["BROWSABLE", "DEFAULT"],
          "autoVerify": true
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#2E6644"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.hopon.app",
          "enableGooglePay": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
